.pred-tooltip { background: var(--bg-elevated); border: 1px solid var(--border-strong); border-radius: 8px; padding: 10px 14px; }
.pred-tooltip-label { font-size: 12px; color: var(--text-muted); margin-bottom: 4px; }
.pred-tooltip-value { font-family: var(--font-mono); font-size: 14px; font-weight: 600; color: var(--gold-light); }
/* New Prediction Page Styles */
.pred-summary {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-top: 16px;
  padding-top: 16px;
  border-top: 1px solid var(--border);
}
.pred-summary-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.pred-summary-label {
  font-size: 12px;
  color: var(--text-muted);
}
.pred-summary-value {
  font-family: var(--font-mono);
  font-size: 13px;
  font-weight: 600;
  color: var(--text-primary);
}
.pred-summary-value.var-positive {
  color: var(--success);
}
.pred-summary-value.var-negative {
  color: var(--danger);
}
.pred-summary-value.var-neutral {
  color: var(--warning);
}
.sap-table .selected-row {
  background: var(--teal-dim) !important;
  border-left: 3px solid var(--teal);
}
.sap-table .var-positive {
  color: var(--success);
  font-weight: 600;
}
.sap-table .var-negative {
  color: var(--danger);
  font-weight: 600;
}
.sap-table .var-neutral {
  color: var(--warning);
  font-weight: 600;
}
/* PAGE SCENARIOS */
.scen-form-head {
  display: flex;
  align-items: flex-start;
