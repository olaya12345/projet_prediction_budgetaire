Thinking: Now let me rewrite consolidate_all.py for the new format. The key changes:
1. Accept classe parameter (6 or 7)
2. For each account calculate:
   - Réalisé n (the realized amount for the current year)
   - Moyenne 5 ans (average of last 5 years)
   - Prédiction n+1 (prediction for next year)
   - Variation % (between prediction and realized)
3. Return data organized by month columns
The calculation logic:
- Classe 6 (charges): Total = Total Debit - Total Credit
- Classe 7 (produits): Total = Total Credit - Total Debit
# Wrote ia_server\models\consolidate_all.py
# ============================================
# FICHIER : consolidate_all.py
# RÔLE    : Calcule les prédictions par classe (6 ou 7)
#           Format : rows=comptes, cols=mois (Réalisé, Moy, Prédit, Var)
# ============================================
import sys
import os
sys.path.append(os.path.join(os.path.dirname(__file__), '..'))
import pandas as pd
import numpy as np
from scipy import stats
MOIS_FR = ['Janvier', 'Février', 'Mars', 'Avril', 'Mai', 'Juin',
           'Juillet', 'Août', 'Septembre', 'Octobre', 'Novembre', 'Décembre']
def get_data_path():
    current_file = os.path.abspath(__file__)
    project_root = os.path.dirname(os.path.dirname(current_file))
    return os.path.join(project_root, "data", "data_for_ai.csv")
def calculer_montant_final(row, classe):
    """Calcule le montant final selon la classe."""
    if classe == 6:
        return row['Debit'] - row['Credit']
    else:
        return row['Credit'] - row['Debit']
def calculer_predictions_par_classe(classe: int, year_target: int, year_realise: int = None):
    """
    Calcule les prédictions pour tous les comptes d'une classe donnée.
    
    Args:
        classe: 6 (charges) ou 7 (produits)
        year_target: année de prédiction (n+1)
        year_realise: année des réalisés (n), par défaut year_target - 1
    
    Returns:
        dict avec les données formatées pour le dashboard
    """
    if year_realise is None:
        year_realise = year_target - 1
    
    data_path = get_data_path()
    if not os.path.exists(data_path):
        return {"error": f"Fichier introuvable : {data_path}"}
    
    df = pd.read_csv(data_path)
    
    df_classe = df[df['classe'] == classe].copy()
    if len(df_classe) == 0:
        return {"error": f"Aucun compte trouvé pour la classe {classe}"}
    
    df_classe['date'] = pd.to_datetime(df_classe['date'])
    df_classe['annee'] = df_classe['date'].dt.year
    df_classe['mois'] = df_classe['date'].dt.month
    
    df_classe['montant_final'] = df_classe.apply(
        lambda row: calculer_montant_final(row, classe), axis=1
    )
    
    comptes = sorted(df_classe['account'].unique())
    
    resultats = []
    
    for compte in comptes:
        df_acc = df_classe[df_classe['account'] == compte].copy()
        
        libelle = df_acc['libelle'].iloc[0] if 'libelle' in df_acc.columns and pd.notna(df_acc['libelle'].iloc[0]) else str(compte)
        
        annees_disponibles = sorted(df_acc['annee'].unique())
        if len(annees_disponibles) < 2:
            continue
        
        mois_data = []
        
        for mois_num in range(1, 13):
            mois_annee_realise = df_acc[(df_acc['annee'] == year_realise) & (df_acc['mois'] == mois_num)]
            realise = mois_annee_realise['montant_final'].sum() if len(mois_annee_realise) > 0 else 0
            
            nb_annees_histo = min(5, len(annees_disponibles))
            annees_histo = annees_disponibles[-nb_annees_histo:]
            
            vals_mois = []
            for ann in annees_histo:
                data_mois = df_acc[(df_acc['annee'] == ann) & (df_acc['mois'] == mois_num)]
                if len(data_mois) > 0:
                    vals_mois.append(data_mois['montant_final'].sum())
            
            moyenne = np.mean(vals_mois) if vals_mois else 0
            
            prediction = moyenne
            
            if realise != 0:
                variation = ((prediction - realise) / abs(realise)) * 100
            else:
                variation = 100 if prediction > 0 else 0
            
            mois_data.append({
                'mois_num': mois_num,
                'mois': MOIS_FR[mois_num - 1],
                'realise': round(realise, 2),
                'moyenne': round(moyenne, 2),
                'prediction': round(prediction, 2),
                'variation': round(variation, 2)
            })
        
        total_realise = sum(m['realise'] for m in mois_data)
        total_moyenne = sum(m['moyenne'] for m in mois_data)
        total_prediction = sum(m['prediction'] for m in mois_data)
        
        if total_realise != 0:
            total_variation = ((total_prediction - total_realise) / abs(total_realise)) * 100
        else:
            total_variation = 100 if total_prediction > 0 else 0
        
        resultats.append({
            'account': str(compte),
            'libelle': libelle,
            'classe': classe,
            'annee_realise': year_realise,
            'annee_prediction': year_target,
            'donnees_mensuelles': mois_data,
            'totaux': {
                'realise': round(total_realise, 2),
                'moyenne': round(total_moyenne, 2),
                'prediction': round(total_prediction, 2),
                'variation': round(total_variation, 2)
            }
        })
    
    total_realise_global = sum(r['totaux']['realise'] for r in resultats)
    total_moyenne_global = sum(r['totaux']['moyenne'] for r in resultats)
    total_prediction_global = sum(r['totaux']['prediction'] for r in resultats)
    
    if total_realise_global != 0:
        total_variation_global = ((total_prediction_global - total_realise_global) / abs(total_realise_global)) * 100
    else:
        total_variation_global = 100 if total_prediction_global > 0 else 0
    
    return {
        'success': True,
        'classe': classe,
        'annee_realise': year_realise,
        'annee_prediction': year_target,
        'nb_comptes': len(resultats),
        'comptes': resultats,
        'totaux_globaux': {
            'realise': round(total_realise_global, 2),
            'moyenne': round(total_moyenne_global, 2),
            'prediction': round(total_prediction_global, 2),
            'variation': round(total_variation_global, 2)
        },
        'mois': MOIS_FR
    }
def get_comptes_par_classe(classe: int):
    """Retourne la liste des comptes pour une classe donnée."""
    data_path = get_data_path()
    if not os.path.exists(data_path):
        return []
    
    df = pd.read_csv(data_path)
    df_classe = df[df['classe'] == classe]
    
    return sorted(df_classe['account'].unique().tolist())
if __name__ == "__main__":
    print("="*70)
    print("  TEST - Calcul des prédictions par classe")
    print("="*70)
    
    print("\n📊 Classe 6 (Charges) - Année 2026 :")
    result_classe6 = calculer_predictions_par_classe(classe=6, year_target=2027)
    if 'error' in result_classe6:
        print(f"  Erreur: {result_classe6['error']}")
    else:
        print(f"  Comptes traités: {result_classe6['nb_comptes']}")
        print(f"  Total Réalisé: {result_classe6['totaux_globaux']['realise']:,.2f} DH")
        print(f"  Total Moyenne: {result_classe6['totaux_globaux']['moyenne']:,.2f} DH")
        print(f"  Total Prédiction: {result_classe6['totaux_globaux']['prediction']:,.2f} DH")
        print(f"  Variation: {result_classe6['totaux_globaux']['variation']:.2f}%")
        
        print("\n  Exemple - Premier compte:")
        if result_classe6['comptes']:
            c = result_classe6['comptes'][0]
            print(f"    {c['account']} - {c['libelle']}")
            print(f"    Jan: Réalisé={c['donnees_mensuelles'][0]['realise']:,.0f}, "
                  f"Moy={c['donnees_mensuelles'][0]['moyenne']:,.0f}, "
                  f"Prédit={c['donnees_mensuelles'][0]['prediction']:,.0f}, "
                  f"Var={c['donnees_mensuelles'][0]['variation']:.1f}%")
    
    print("\n" + "-"*70)
    
    print("\n📊 Classe 7 (Produits) - Année 2026 :")
    result_classe7 = calculer_predictions_par_classe(classe=7, year_target=2027)
    if 'error' in result_classe7:
        print(f"  Erreur: {result_classe7['error']}")
    else:
        print(f"  Comptes traités: {result_classe7['nb_comptes']}")
        print(f"  Total Réalisé: {result_classe7['totaux_globaux']['realise']:,.2f} DH")
        print(f"  Total Moyenne: {result_classe7['totaux_globaux']['moyenne']:,.2f} DH")
        print(f"  Total Prédiction: {result_classe7['totaux_globaux']['prediction']:,.2f} DH")
